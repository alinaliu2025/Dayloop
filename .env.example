# Copy this file to `.env` and fill in real values. `.env` is gitignored —
# never commit it.
#
#   cp .env.example .env
#
# Telegram bot token from @BotFather
TELEGRAM_TOKEN=ABCDE:token-from-botfather

# Your numeric Telegram id (printed when you /start). Locks the bot to you.
# Leave blank to keep the bot open to anyone who finds it.
TELEGRAM_USER_ID=

# OpenAI API key (from the account you were granted access to)
OPENAI_API_KEY=sk-your-openai-key